
generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  images      Image[]
  createdAt   DateTime @default(now())
}

model Image {
  id        String  @id @default(uuid())
  url       String  // Aquí guardaremos la URL que nos dé Cloudinary
  publicId  String  // ID interno de Cloudinary para poder borrarla después
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}